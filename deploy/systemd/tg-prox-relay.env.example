TGPROX_RELAY_LISTEN_HOST=0.0.0.0
TGPROX_RELAY_LISTEN_PORT=8443
TGPROX_RELAY_TLS_KEY_PATH=/etc/letsencrypt/live/relay.unitops.pro/privkey.pem
TGPROX_RELAY_TLS_CERT_PATH=/etc/letsencrypt/live/relay.unitops.pro/fullchain.pem
TGPROX_RELAY_SHARED_TOKEN=replace-with-random-secret
TGPROX_RELAY_CONNECT_TIMEOUT_MS=10000
TGPROX_RELAY_LOG_FILE=/var/log/tg-prox-relay.log
